{
  "quiet": true,
  "ignoreerrors": true,
  "no_abort_on_error": true,
  "nooverwrites": true,
  "ratelimit": 500000,
  "downloader": "ffmpeg",
  "hls_use_mpegts": true,
  "check_formats": true,
  "extractor_args": {
    "youtube": {
      "player_client": ["android", "web"],
      "skip": ["dash", "hls"]
    }
  },
  "abort_on_unavailable_fragments": false,
 "format": "bestvideo[height>=720][ext=mp4][vcodec^=avc]+bestaudio[ext=m4a]/best[height>=720][ext=mp4]/best[height>=720]",
  "retries": 10,
  "fragment_retries": 20,
  "retry_streams": 5,
  "socket_timeout": 60,
  "merge_output_format": "mp4",
  "force-write-archive": true,
  "simulate": false,
  "download_archive": "/app/log/downloaded_videos.txt"
}
